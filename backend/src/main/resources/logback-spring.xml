<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>
%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ} app=ecommerce level=%-5level logger=%logger{36} thread=%thread trace=%X{traceId} span=%X{spanId} correlationId=%X{correlationId} msg="%msg"%n
            </pattern>
        </encoder>
    </appender>

    <appender name="RollingFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>./logs/spring-boot-logger.log</file>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>
%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ} app=ecommerce level=%-5level logger=%logger thread=%thread trace=%X{traceId} span=%X{spanId} correlationId=%X{correlationId} msg="%msg"%n
            </pattern>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>./logs/archived/spring-boot-logger-%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>10MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
        </rollingPolicy>
    </appender>

    <!-- Default root logger -->
    <root level="INFO">
        <appender-ref ref="Console" />
        <appender-ref ref="RollingFile" />
    </root>

    <!-- Application-specific logger -->
    <logger name="com.jazz.ecommerce" level="DEBUG"/>

    <!-- Spring Security logger -->
    <logger name="org.springframework.security" level="INFO"/>

</configuration>
