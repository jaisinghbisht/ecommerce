<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true">

  <!-- Application name property (falls back to 'ecommerce') -->
  <property name="APP_NAME" value="${spring.application.name:-ecommerce}"/>

  <!-- Console appender with a consistent key=value structured pattern -->
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>
%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ} app="%property{APP_NAME}" level=%-5level logger="%logger{36}" thread="%thread" trace="%X{traceId:-}" span="%X{spanId:-}" msg="%replace(%msg){'\"','\\\"'}"%n%ex{full}
      </pattern>
    </encoder>
  </appender>

  <!-- Root logger -->
  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>

</configuration>
